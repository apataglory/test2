# ========================================
# DECKDROP ENVIRONMENT VARIABLES
# ========================================
# Copy this file to .env.local and fill in your values

# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
# 
# Local development:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/deckdrop"
#
# Vercel Postgres (recommended for production):
#   Set automatically in Vercel dashboard
#
# Railway.app (free tier):
#   Get from Railway dashboard
DATABASE_URL=""

# ========================================
# AUTHENTICATION
# ========================================
# JWT Secret - Generate a strong random string for production
# Use: openssl rand -base64 32
# Or generate at: https://www.random.org
JWT_SECRET=""

# How long JWT tokens are valid
JWT_EXPIRES_IN="7d"

# ========================================
# PAYMENT GATEWAY (Flutterwave)
# ========================================
# Get these keys from https://dashboard.flutterwave.com
# 
# Test Mode: Use FLWPUBK_TEST_* and FLWSECK_TEST_*
# Live Mode: Use FLWPUBK_LIVE_* and FLWSECK_LIVE_* (production only)

# Public key - Safe to expose in frontend
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=""

# Secret key - NEVER expose in frontend, server-side only
FLUTTERWAVE_SECRET_KEY=""

# ========================================
# APP CONFIGURATION
# ========================================
# Production URL where app is hosted
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# API endpoint URL
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# WebSocket server URL (for real-time updates)
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"

# ========================================
# ENVIRONMENT
# ========================================
# development | production
NODE_ENV="development"

# ========================================
# OPTIONAL: ADVANCED FEATURES
# ========================================

# Google Maps API Key (for enhanced tracking)
# Get from: https://cloud.google.com/maps-platform
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# SendGrid API Key (for email notifications)
# Get from: https://sendgrid.com
# SENDGRID_API_KEY=""

# Sentry Error Tracking (for production)
# Get from: https://sentry.io
# NEXT_PUBLIC_SENTRY_DSN=""

# ========================================
# INSTRUCTIONS
# ========================================
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in the values with your actual keys
# 3. Never commit .env.local to git
# 4. For Vercel deployment:
#    - Set environment variables in Vercel dashboard
#    - Don't use .env.local in production
# 5. For GitHub:
#    - .env.local is in .gitignore (not tracked)
#    - Only .env.example is committed
